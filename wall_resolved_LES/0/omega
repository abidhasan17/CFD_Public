FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}

#include        "include/initialConditions"

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 0.082;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           $internalField;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }

    wall
    {
        type            omegaWallFunction;
        value           $internalField;
    }

    frontAndBack
    {
        type            omegaWallFunction;
        value           $internalField;
    }
}

