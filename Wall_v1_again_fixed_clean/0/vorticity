FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      vorticity;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform (0 -0 0);

boundaryField
{
    inlet
    {
        type            calculated;
        value           uniform (0 -0 0);
    }
    outlet
    {
        type            calculated;
        value           uniform (0 -0 0);
    }
    ground
    {
        type            calculated;
        value           uniform (0 -0 0);
    }
    frontAndBack
    {
        type            calculated;
        value           uniform (0 -0 0);
    }
    buildings
    {
        type            calculated;
        value           uniform (0 -0 0);
    }
    WERFL
    {
        type            calculated;
        value           uniform (0 -0 0);
    }
}


